                "required": [
                  "reason"
                ]
              },
              {
                "properties": {
                  "code": {
                    "const": "refusal"
                  },
                  "reason": {
                    "enum": [
                      "policy_denied",
                      "interactive_input_required",
                      "authentication_required"
                    ]
                  }
                },
                "required": [
                  "code",
                  "reason"
                ]
              },
              {
                "properties": {
                  "code": {
                    "const": "malformed"
