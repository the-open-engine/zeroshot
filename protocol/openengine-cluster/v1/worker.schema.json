        {
          "if": {
            "properties": {
              "status": {
                "const": "error"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "oneOf": [
              {
                "properties": {
                  "reason": {
                    "const": "declared_failure"
