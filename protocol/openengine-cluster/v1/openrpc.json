  "openrpc": "1.3.2",
  "x-generic-subscription-framing": {
    "description": "watch establishes a subscription via one normal JSON-RPC result; subsequent delivery uses the generic notification methods below, shared by any future subscription-based method (e.g. logs/attach). There is no watch/event, watch/cancel, or watch/closed method on the wire.",
