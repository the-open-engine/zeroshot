{
  "artifactProfile": {
    "allowedMediaTypes": [
      "application/json"
    ],
    "allowedTypeIds": [
      "openengine.result@1"
    ],
    "minimumRedaction": "internal"
  },
  "binding": {
    "profile": "openengine.worker.a2a/1.0",
    "protocol": "a2a",
    "version": "1.0"
  },
  "capabilityPolicy": {
    "autonomy": "strict",
    "permissionPolicy": "policy.strict@1"
  },
  "contract": {
    "errors": [
      "timeout",
      "crash",
      "malformed",
      "refusal"
    ],
    "input": {
      "kind": "string"
    },
    "output": {
      "kind": "string"
    },
    "verifier": null
  },
  "credentialRequirements": [
    "credential.test@1"
  ],
  "graphProfiles": [
    "openengine.graph.full/v1"
  ],
  "worker": "mock.a2a@1"
}
