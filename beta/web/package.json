{
  "name": "@beta-uss-earth/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build --outDir dist/client && vite build --ssr src/entry-server.tsx --outDir dist/server && node scripts/render-shell.mjs",
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0 --outDir dist/client",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@beta-uss-earth/types": "workspace:*",
    "solid-js": "^1.9.7"
  },
  "devDependencies": {
    "typescript": "5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-solid": "^2.11.7"
  }
}
