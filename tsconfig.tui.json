{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "jsx": "react",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "lib/tui",
    "rootDir": "src/tui"
  },
  "include": ["src/tui/**/*.ts", "src/tui/**/*.tsx"],
  "exclude": ["node_modules", "lib"]
}
