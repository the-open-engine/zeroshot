{
  "defaultProvider": "claude",
  "agents": [
    {
      "id": "worker",
      "role": "implementation",
      "timeout": 0,
      "maxRetries": 1,
      "triggers": [{ "topic": "ISSUE_OPENED", "action": "execute_task" }],
      "prompt": "FAKE_AGENT_ID=worker Execute the bounded test task.",
      "hooks": {
        "onComplete": {
          "action": "publish_message",
          "config": {
            "topic": "CLUSTER_COMPLETE",
            "content": {
              "text": "Malformed worker completion.",
              "data": {
                "result": {
                  "summary": "invalid inline output",
                  "status": "succeeded",
                  "artifacts": [{ "bytes": "forbidden" }]
                }
              }
            }
          }
        }
      }
    }
  ]
}
